# ---- Server ----
PORT=4000
# The URL your frontend is served from. Used for CORS + PhonePe redirect.
FRONTEND_URL=https://your-zipo-site.example.com

# ---- MongoDB ----
# Free cluster: https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/zipo?retryWrites=true&w=majority

# ---- Google Sign-In ----
# From Google Cloud Console > APIs & Services > Credentials.
# Must be THE SAME client ID used in index.html's GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Only this email is allowed to edit site content / view bookings.
ADMIN_EMAIL=zipocarwash@gmail.com

# ---- PhonePe Payment Gateway ----
# From PhonePe Business dashboard > Developer Settings.
# Use SANDBOX credentials while testing, PRODUCTION ones once you go live.
PHONEPE_CLIENT_ID=your-phonepe-client-id
PHONEPE_CLIENT_SECRET=your-phonepe-client-secret
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=SANDBOX
# The username/password YOU choose and configure in the PhonePe dashboard
# for webhook (callback) authentication — not your login credentials.
PHONEPE_CALLBACK_USERNAME=choose-a-username
PHONEPE_CALLBACK_PASSWORD=choose-a-strong-password
